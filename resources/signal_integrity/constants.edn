;; Physical and empirical constants for signal-integrity's signal-integrity
;; formulas. Extracted from the retired Rust kami-si crate's `const`
;; definitions and inline magic numbers (kotoba-lang/kami-engine,
;; deleted-but-uncommitted working tree, ADR-2607010000). Pure data; loaded
;; once on the JVM by signal-integrity.constants (no network I/O — bundled
;; classpath resource).
;;
;; Datomic/Datascript tx-data shape: a single-entity vector
;; ([{:db/id -1 ...}]), so this file can be handed directly to
;; (d/transact conn (edn/read-string (slurp f))). Keys are already
;; idiomatically namespaced by source subsystem (:tline/* :crosstalk/*
;; :eye/*), so they are kept as-is rather than re-prefixed with a new
;; file-level namespace. signal-integrity.constants/constants reconstitutes
;; the original flat map at read time (dissoc :db/id) so existing keyword
;; lookups are unaffected. See manifest/schema.edn (superproject root) for
;; the accumulated :db/ident attribute definitions.
[{:db/id -1
  ;; transmission_line.rs
  :tline/trace-thickness-mm 0.035          ; 1 oz copper
  :tline/c-mm-per-ps 0.2998                ; speed of light
  :tline/microstrip-loss-base 0.001        ; simplified conductor + dielectric loss
  :tline/stripline-loss-base 0.0008
  :tline/coplanar-loss-base 0.0012

  ;; crosstalk.rs
  :crosstalk/spacing-decay-mm 0.3          ; exponential coupling-vs-spacing decay
  :crosstalk/backward-coefficient 0.25     ; NEXT coupling coefficient
  :crosstalk/forward-coefficient 0.05      ; FEXT coupling coefficient
  :crosstalk/driver-source-impedance-ohm 50.0
  :crosstalk/driver-amplitude-mv 1000.0    ; 1V driver, expressed in mV
  :crosstalk/saturation-floor-mm 0.1       ; min saturation length divisor floor

  ;; eye_diagram.rs
  :eye/samples-per-bit 64
  ;; 64-bit LCG (PCG-style constants); state/seed given as the two's-complement
  ;; signed-long bit pattern equivalent to Rust's unsigned u64 wrapping
  ;; arithmetic (`0xDEAD_BEEF_CAFE_1234u64` == -2401053089206496716i64).
  :eye/lcg-seed -2401053089206496716
  :eye/lcg-multiplier 6364136223846793005
  :eye/lcg-increment 1442695040888963407
  ;; cljs has no 64-bit integer primitive; the cljs port substitutes a
  ;; deterministic 32-bit xorshift PRNG (not bit-compatible with the JVM/Rust
  ;; LCG — see README "Portability notes").
  :eye/xorshift32-seed 3405691582          ; 0xCAFEBABE, any nonzero 32-bit value
  :eye/center-window-start 0.35
  :eye/center-window-end 0.65
  :eye/sigma-multiplier 3.0
  :eye/jitter-pp-multiplier 6.0
  :eye/default-q-factor 20.0}]
